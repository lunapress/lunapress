#!/usr/bin/env php
<?php
declare(strict_types=1);

use Composer\InstalledVersions;
use CuyZ\Valinor\MapperBuilder;
use Gettext\Generator\PoGenerator;
use LunaPress\Cli\Build\Archive\ArchiveCommand;
use LunaPress\Cli\Build\Archive\ZipArchiver;
use LunaPress\Cli\Frontend\Init\FrontendInitCommand;
use LunaPress\Cli\Frontend\Init\DefaultFrontendProjectGenerator;
use LunaPress\Cli\I18n\Pot\Extractor\FileHeaderExtractor\FileHeaderExtractor;
use LunaPress\Cli\I18n\Pot\Extractor\JavascriptExtractor\JavascriptExtractor;
use LunaPress\Cli\I18n\Pot\Extractor\PhpStanExtractor;
use LunaPress\Cli\I18n\Pot\Generator\DefaultPotGenerator;
use LunaPress\Cli\I18n\Pot\MakePotCommand;
use LunaPress\Cli\I18n\Pot\Scanner\PhpStanScanner;
use LunaPress\Cli\I18n\Pot\Scanner\ProjectMetadataScanner;
use LunaPress\Cli\Prefix\PrefixCommand;
use LunaPress\Cli\Prefix\StraussPrefixer;
use LunaPress\Cli\Support\DefaultPathResolver;
use LunaPress\Cli\Support\DefaultProcessFactory;
use LunaPress\Config\DefaultConfigResolver;
use Symfony\Component\Console\Application;
use Symfony\Component\Filesystem\Filesystem;

if (!in_array(PHP_SAPI, ['cli', 'phpdbg', 'embed'], true)) {
    echo 'This application must be run from the command line.' . PHP_EOL;
    exit(1);
}

$pharPath = Phar::running();

if ($pharPath !== '') {
    require_once $pharPath . '/vendor/autoload.php';

    if (isset($_composer_autoload_path) && file_exists($_composer_autoload_path)) {
        require_once $_composer_autoload_path;
    }
} else {
    require_once $_composer_autoload_path ?? __DIR__ . '/../../../vendor/autoload.php';
}

$version = '@git-version@';

if (str_starts_with($version, '@git')) {
    $version = class_exists(InstalledVersions::class)
            ? (InstalledVersions::isInstalled('lunapress/cli')
                    ? InstalledVersions::getPrettyVersion('lunapress/cli')
                    : InstalledVersions::getRootPackage()['pretty_version'])
            : 'dev';
}

$cliPackageRoot = dirname(__DIR__);

$app = new Application('LunaPress CLI', ltrim((string) $version, 'v'));
$projectMetadataScanner = new ProjectMetadataScanner();
$pathResolver = new DefaultPathResolver($cliPackageRoot);

$app->addCommand(new ArchiveCommand(
        new ZipArchiver(),
        new DefaultConfigResolver(),
        $pathResolver
));
$app->addCommand(new PrefixCommand(
        new StraussPrefixer(),
        new DefaultConfigResolver(),
        $pathResolver
));
$app->addCommand(new FrontendInitCommand(
    new DefaultFrontendProjectGenerator($pathResolver),
));
$app->addCommand(new MakePotCommand(
    new DefaultPotGenerator(
        [
            new FileHeaderExtractor($projectMetadataScanner),
            new PhpStanExtractor(
                    new PhpStanScanner()
            ),
            new JavascriptExtractor(
                    new DefaultProcessFactory(),
                    new MapperBuilder()
            ),
        ],
        new PoGenerator(),
        new Filesystem(),
        $projectMetadataScanner,
    ),
    $pathResolver
));
$app->run();