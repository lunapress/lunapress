#!/usr/bin/env php
<?php

use CuyZ\Valinor\MapperBuilder;
use Gettext\Generator\PoGenerator;
use LunaPress\Cli\Frontend\Init\FrontendInitCommand;
use LunaPress\Cli\Frontend\Init\FrontendProjectGenerator;
use LunaPress\Cli\I18n\Pot\Extractor\FileHeaderExtractor\FileHeaderExtractor;
use LunaPress\Cli\I18n\Pot\Extractor\JavascriptExtractor\JavascriptExtractor;
use LunaPress\Cli\I18n\Pot\Extractor\PhpStanExtractor;
use LunaPress\Cli\I18n\Pot\Generator\PotGenerator;
use LunaPress\Cli\I18n\Pot\MakePotCommand;
use LunaPress\Cli\I18n\Pot\Scanner\PhpStanScanner;
use LunaPress\Cli\I18n\Pot\Scanner\ProjectMetadataScanner;
use LunaPress\Cli\Support\PathResolver;
use LunaPress\Cli\Support\ProcessFactory;
use Symfony\Component\Console\Application;
use Symfony\Component\Filesystem\Filesystem;

$pharPath = Phar::running();

if ($pharPath !== '') {
    require_once $pharPath . '/vendor/autoload.php';

    if (isset($_composer_autoload_path) && file_exists($_composer_autoload_path)) {
        require_once $_composer_autoload_path;
    }
} else {
    require_once $_composer_autoload_path ?? __DIR__ . '/../../../vendor/autoload.php';
}

if (!defined('ABSPATH')) {
    define('ABSPATH', '/');
}

$cliPackageRoot = dirname(__DIR__);
$pathResolver = new PathResolver($cliPackageRoot);

$app = new Application('LunaPress CLI', '1.0.0');

$projectMetadataScanner = new ProjectMetadataScanner();

$app->addCommand(new FrontendInitCommand(
    new FrontendProjectGenerator($pathResolver),
));
$app->addCommand(new MakePotCommand(
    new PotGenerator(
        [
            new FileHeaderExtractor($projectMetadataScanner),
            new PhpStanExtractor(
                    new PhpStanScanner()
            ),
            new JavascriptExtractor(
                    new ProcessFactory(),
                    new MapperBuilder()
            ),
        ],
        new PoGenerator(),
        new Filesystem(),
        $projectMetadataScanner,
    )
));
$app->run();