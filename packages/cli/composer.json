{
    "name": "lunapress/cli",
    "description": "CLI for development",
    "type": "library",
    "bin": [
        "bin/lunapress"
    ],
    "authors": [
        {
            "name": "Onepix",
            "homepage": "https://onepix.net",
            "role": "Company"
        },
        {
            "name": "0zd0",
            "role": "Lead Developer",
            "homepage": "https://github.com/0zd0"
        }
    ],
    "autoload": {
        "psr-4": {
            "LunaPress\\Cli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LunaPress\\Cli\\Test\\": "tests/",
            "LunaPress\\Cli\\Robo\\": "robo/"
        }
    },
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "brianhenryie/strauss-phar",
                "version": "0.27.0",
                "dist": {
                    "url": "https://github.com/BrianHenryIE/strauss/releases/download/0.27.0/strauss.phar",
                    "type": "file",
                    "shasum": "437c9a43cafbd60eeb22d09f83d1fcd939140c00"
                },
                "bin": [
                    "strauss.phar"
                ]
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-zip": "*",
        "ext-json": "*",
        "symfony/console": "^v7",
        "symfony/finder": "^v7.3",
        "symfony/filesystem": "^v7.4.8",
        "symfony/process": "^v7.4.8",
        "mustache/mustache": "^v3.0.0",
        "gettext/gettext": "^v5.7.3",
        "lunapress/wp-i18n-contracts": "@dev",
        "lunapress/foundation-contracts": "@dev",
        "lunapress/config": "@dev",
        "phpstan/phpstan": "^2.1.32",
        "cuyz/valinor": "^2.3.2",
        "brianhenryie/strauss-phar": "0.27.0"
    },
    "require-dev": {
        "pestphp/pest": "^v4",
        "mikey179/vfsstream": "^v1.6.12",
        "mockery/mockery": "^1.6.12"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
